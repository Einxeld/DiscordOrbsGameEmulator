<Window x:Class="GameEmulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GameEmulator"
        Title="Discord Orbs Game Emulator"
        Height="650" Width="820"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Icon="/star64.png">

    <Window.Resources>

        <SolidColorBrush x:Key="BgBase"       Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgSurface"    Color="#27273A"/>
        <SolidColorBrush x:Key="BgItem"       Color="#313145"/>
        <SolidColorBrush x:Key="BgItemHover"  Color="#3A3A52"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#7C9EF8"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#6ED89A"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#F28B82"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#F5A742"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E0E0F0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#8888A8"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#44445A"/>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InstallButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#7C9EF8"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>

        <Style x:Key="RunButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#6ED89A"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>

        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#F28B82"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>

        <Style x:Key="ReloadButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#44445A"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
        </Style>

        <Style x:Key="FolderButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#7C9EF8"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>

        <Style x:Key="UrlBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313145"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="CaretBrush" Value="#7C9EF8"/>
            <Setter Property="BorderBrush" Value="#44445A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#55556A" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="GameItemTemplate" DataType="{x:Type local:GameEntry}">
            <Border x:Name="ItemBorder"
                    Background="#313145"
                    CornerRadius="8"
                    Margin="0,4,0,4"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <Ellipse x:Name="StatusDot"
                                     Width="8" Height="8"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center"
                                     Fill="#44445A"/>
                            <TextBlock Text="{Binding GameName}"
                                       Foreground="#E0E0F0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Border x:Name="StatusBadge"
                                    Background="#44445A"
                                    CornerRadius="4"
                                    Padding="6,1"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="StatusText"
                                           Text="не установлена"
                                           Foreground="#8888A8"
                                           FontSize="10"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding ExePath}"
                                   Foreground="#666688"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="480"
                                   ToolTip="{Binding ExePath}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0">
                        <Button Content="Установить"
                                Style="{StaticResource InstallButton}"
                                Margin="0,0,6,0"
                                IsEnabled="{Binding CanInstall}"
                                Tag="{Binding}"
                                Click="InstallButton_Click"/>
                        <Button Content="▶  Запустить"
                                Style="{StaticResource RunButton}"
                                Margin="0,0,6,0"
                                IsEnabled="{Binding IsInstalled}"
                                Tag="{Binding}"
                                Click="RunButton_Click"/>
                        <Button Content="Удалить"
                                Style="{StaticResource DeleteButton}"
                                Margin="0,0,6,0"
                                IsEnabled="{Binding IsInstalled}"
                                Tag="{Binding}"
                                Click="DeleteButton_Click"/>
                        <Button Content="📂 Обзор"
                                Style="{StaticResource FolderButton}"
                                Margin="0,0,6,0"
                                Tag="{Binding}"
                                Click="OpenFolderButton_Click"/>
                    </StackPanel>
                </Grid>

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#313145"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                <Setter Property="Background" Value="#2A3A35"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                    <Setter TargetName="StatusDot"   Property="Fill"       Value="#6ED89A"/>
                    <Setter TargetName="StatusBadge" Property="Background" Value="#1E4033"/>
                    <Setter TargetName="StatusText"  Property="Text"       Value="установлена"/>
                    <Setter TargetName="StatusText"  Property="Foreground" Value="#6ED89A"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </Window.Resources>

    <!-- ══ OUTER WRAPPER ══ -->
    <Grid>

        <!-- ══ LAUNCHER UI (hidden when emulate flag is passed) ══ -->
        <Grid x:Name="LauncherRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="161*"/>
                <ColumnDefinition Width="660*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="#27273A"
                    BorderBrush="#44445A"
                    BorderThickness="0,0,0,1"
                    Padding="20,14">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image x:Name="Star" Height="45" Source="/star64.png" Stretch="Fill" Margin="0,0,7,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Эмуляция запуска игр для Discord Orbs"
                                       Foreground="#E0E0F0"
                                       FontSize="17"
                                       FontWeight="Bold"/>
                            <TextBlock Text="По указанному пути будет скопирован этот exe и запущен с именем игры"
                                       Foreground="#8888A8"
                                       FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- URL BAR -->
            <Border Grid.Row="1" Grid.ColumnSpan="2"
                    Background="#27273A"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto" MinWidth="135.573"/>
                        <ColumnDefinition Width="Auto" MinWidth="163.51"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="UrlTextBox"
                             Style="{StaticResource UrlBox}"
                             Text="https://raw.githubusercontent.com/Einxeld/DiscordOrbsGameEmulator/refs/heads/main/games.txt"
                             Margin="0,0,5,0"/>
                    <Button
                            Content="Загрузить список"
                            Style="{StaticResource InstallButton}"
                            Margin="5,2,5,2"
                            Click="LoadList_Click" Grid.Column="1"/>
                    <Button Grid.Column="2"
                            Content="Перепроверить файлы"
                            Style="{StaticResource ReloadButton}"
                            Click="RefreshStatus_Click" Margin="5,2,0,2"/>
                </Grid>
            </Border>

            <!-- STATS BAR -->
            <Border Grid.Row="2" Grid.ColumnSpan="2"
                    Background="#222233"
                    BorderBrush="#44445A"
                    BorderThickness="0,1,0,1"
                    Padding="20,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TotalCount"
                               Text="Всего: 0"
                               Foreground="#8888A8"
                               FontSize="12"
                               Margin="0,0,20,0"/>
                    <TextBlock x:Name="InstalledCount"
                               Text="Установлено: 0"
                               Foreground="#6ED89A"
                               FontSize="12"
                               Margin="0,0,20,0"/>
                    <TextBlock x:Name="NotInstalledCount"
                               Text="Не установлено: 0"
                               Foreground="#8888A8"
                               FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- MAIN LIST -->
            <ScrollViewer Grid.Row="3" Grid.ColumnSpan="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,8,14,8">
                <StackPanel>
                    <Border x:Name="EmptyState"
                            Visibility="Visible"
                            Padding="40"
                            HorizontalAlignment="Center"
                            Margin="0,40,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📋"
                                       FontSize="40"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12" Foreground="White"/>
                            <TextBlock Text="Введите URL и нажмите «Загрузить список»"
                                       Foreground="#8888A8"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="LoadingState"
                            Visibility="Collapsed"
                            Padding="40"
                            HorizontalAlignment="Center"
                            Margin="0,40,0,0">
                        <TextBlock Text="⏳  Загрузка..."
                                   Foreground="#8888A8"
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <ItemsControl x:Name="GamesList"
                                  ItemTemplate="{StaticResource GameItemTemplate}"
                                  Visibility="Collapsed">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- STATUS BAR -->
            <Border Grid.Row="4" Grid.ColumnSpan="2"
                    Background="#27273A"
                    BorderBrush="#44445A"
                    BorderThickness="0,1,0,0"
                    Padding="20,8">
                <TextBlock x:Name="StatusBar"
                           Text="Готово"
                           Foreground="#8888A8"
                           FontSize="11"/>
            </Border>
        </Grid>

        <!-- ══ EMULATION OVERLAY (shown instead when launched with emulate) ══ -->
        <Grid x:Name="EmulationOverlay"
              Visibility="Collapsed"
              Background="#1E1E2E">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <Image Source="/star.png" Stretch="Fill" Cursor="" Height="86" Width="86"/>

                <TextBlock x:Name="EmulationTitle"
                           Text=""
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#E0E0F0"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="идёт эмуляция игры"
                           FontSize="14"
                           Foreground="#8888A8"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,32"/>

                <!-- Animated progress bar -->
                <Border Width="320" Height="4"
                    CornerRadius="2"
                    Background="#313145"
                    ClipToBounds="True">

                    <Border Height="4"
                        CornerRadius="2"
                        Background="#7C9EF8" Margin="85,0,85,0">

                        <Border.RenderTransform>
                            <TranslateTransform x:Name="MoveTransform" />
                        </Border.RenderTransform>

                        <Border.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                            From="-320" To="320"
                                            Duration="0:0:2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                </Border>

                <TextBlock Text="Discord Orbs засчитает время сессии"
                           FontSize="11"
                           Foreground="#55556A"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>